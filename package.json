{
  "name": "bernspedras-topology-app",
  "version": "2.1.3",
  "scripts": {
    "build": "go run github.com/magefile/mage -v build:linux build:linuxARM64 && webpack -c ./.config/webpack/webpack.config.ts --env production",
    "build:frontend": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "build:backend": "go run github.com/magefile/mage -v build:linux build:linuxARM64",
    "build:backend:amd64": "go run github.com/magefile/mage -v build:linux",
    "build:backend:arm64": "go run github.com/magefile/mage -v build:linuxARM64",
    "dev:backend": "go run github.com/magefile/mage -v build:backend",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache src/",
    "lint:fix": "npm run lint -- --fix",
    "rebuild": "npm run build:backend && npm run build:frontend && docker compose restart grafana",
    "seed": "docker compose exec grafana rm -rf /var/lib/grafana/topology-data && docker compose cp ../topology-dashboard/topologies/. grafana:/var/lib/grafana/topology-data/",
    "seed:pull": "docker compose cp grafana:/var/lib/grafana/topology-data /tmp/_topo_pull && rm -rf ../topology-dashboard/topologies && mv /tmp/_topo_pull ../topology-dashboard/topologies",
    "server": "npm run build && docker compose up --build",
    "server:clean": "docker compose down -v --rmi local && docker compose up --build",
    "demo": "npm run build && cd provisioning/demo && docker compose -f docker-compose.demo.yaml up --build",
    "demo:clean": "cd provisioning/demo && docker compose -f docker-compose.demo.yaml down -v --rmi local",
    "sign": "npx --yes @grafana/sign-plugin@latest"
  },
  "author": "Bernardo Frankenfeld",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/data": "^11.4.0",
    "@grafana/runtime": "^11.4.0",
    "@grafana/schema": "^11.4.0",
    "@grafana/ui": "^11.4.0",
    "@types/dompurify": "^3.0.5",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "dompurify": "^3.4.1",
    "fflate": "^0.8.2",
    "marked": "^15.0.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.22.0",
    "rxjs": "7.8.2",
    "uplot": "^1.6.32",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@grafana/eslint-config": "^9.0.0",
    "@grafana/tsconfig": "^2.0.1",
    "@swc/core": "^1.15.0",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/dagre": "^0.7.54",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.32.0",
    "eslint-webpack-plugin": "^5.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.1.0",
    "identity-obj-proxy": "^3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "replace-in-file-webpack-plugin": "^1.0.0",
    "sass": "^1.89.0",
    "sass-loader": "^16.0.0",
    "serialize-javascript": "^7.0.5",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.0",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "dompurify": "^3.4.1",
    "immutable": "^5.1.5",
    "uuid": "^14.0.0"
  }
}
